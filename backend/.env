# Server configuration
PORT=4000

# MongoDB — use localhost for local dev, mongodb://mongodb:27017/rse for Docker
MONGODB_URI=mongodb://localhost:27017/rse

# CORS — set to the frontend origin as seen by the browser
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=schlüssel
JWT_TTL=300

# Cookie security — only enable when actually served over HTTPS (a real
# deployment on a domain), NOT for local docker-compose/dev over plain http://.
# NODE_ENV=production alone does NOT mean HTTPS; that conflation caused the
# access_token cookie to be silently dropped by the browser under docker-compose.
COOKIE_SECURE=false

PREFILL_USERS=true