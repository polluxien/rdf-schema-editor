# After pulling add to gitignore

# Enable/disable mock data (set VITE_USE_MOCK_DATA=false to use the real backend)
VITE_USE_MOCK_DATA=true
VITE_REAL_FETCH=false

# Backend API base URL — must match where the backend actually listens
VITE_APP_API_BASE_URL=http://localhost:4000
VITE_FRONTEND_BASE_URL=http://localhost:5173
